# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ReactNativeExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'ReactNativeExampleTests' do
    inherit! :complete
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # Xcode 26 requires code signing for all targets including Pods
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        bc.build_settings['CODE_SIGN_IDENTITY'] = '-'
      end
    end

    # Disable folly coroutines — coro sources are not shipped with RCT-Folly pod
    # but Xcode 26 compiler enables __cpp_impl_coroutine, causing FOLLY_HAS_COROUTINES=1
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        existing = bc.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || ['$(inherited)']
        unless existing.include?('FOLLY_CFG_NO_COROUTINES=1')
          existing << 'FOLLY_CFG_NO_COROUTINES=1'
          bc.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = existing
        end
      end
    end

    # Also patch xcconfig files so the definition is not overridden
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig_path|
      xcconfig = File.read(xcconfig_path)
      unless xcconfig.include?('FOLLY_CFG_NO_COROUTINES')
        xcconfig = xcconfig.gsub(
          /^(GCC_PREPROCESSOR_DEFINITIONS = .*)$/,
          '\1 FOLLY_CFG_NO_COROUTINES=1'
        )
        File.write(xcconfig_path, xcconfig)
      end
    end
  end
end
